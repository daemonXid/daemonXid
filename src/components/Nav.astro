---
import SocialLinks from './SocialLinks.astro'
import { detectLang, withLang, type SiteLang } from '../lib/i18n'

interface Props {
  lang?: SiteLang
  langToggleHref?: string
}

const current = Astro.url.pathname
const currentLang = Astro.props.lang ?? detectLang(current)
const forcedLangToggleHref = Astro.props.langToggleHref
const labels = currentLang === 'ko'
  ? { home: '홈', resume: '이력서', portfolio: '포트폴리오', blog: '블로그' }
  : { home: 'Home', resume: 'Resume', portfolio: 'Portfolio', blog: 'Blog' }

const links = [
  { href: withLang('/', currentLang), label: labels.home },
  { href: withLang('/resume', currentLang), label: labels.resume },
  { href: withLang('/portfolio', currentLang), label: labels.portfolio },
  { href: withLang('/blog', currentLang), label: labels.blog },
]

const isActive = (href: string) =>
  href === '/ko' || href === '/' ? current === href : current.startsWith(href)

const otherLang: SiteLang = currentLang === 'ko' ? 'en' : 'ko'
const otherLangHref = forcedLangToggleHref ?? withLang(current, otherLang)
---

<nav class="nav-bar">
  <div class="nav-inner">
    <a href={withLang('/', currentLang)} class="logo">
      <span class="logo-name">Wonsub Song</span>
      <span class="logo-sub">(Tony)</span>
    </a>

    <div class="nav-right nav-right--desktop">
      <ul class="nav-links">
        {links.map(l => (
          <li>
            <a href={l.href} class={`nav-link ${isActive(l.href) ? 'nav-link--active' : ''}`}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
      <a href={otherLangHref} class="lang-toggle" aria-label={`Switch language to ${otherLang.toUpperCase()}`}>
        <span class:list={['lang-chip', currentLang === 'ko' && 'lang-chip--active']}>KO</span>
        <span class:list={['lang-chip', currentLang === 'en' && 'lang-chip--active']}>EN</span>
      </a>
      <SocialLinks size="sm" />
    </div>

    <details class="nav-mobile">
      <summary class="nav-mobile-summary" aria-label="Toggle navigation">
        <span class="nav-mobile-lang">
          <span class:list={['lang-chip', currentLang === 'ko' && 'lang-chip--active']}>KO</span>
          <span class:list={['lang-chip', currentLang === 'en' && 'lang-chip--active']}>EN</span>
        </span>
        <span class="hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="nav-mobile-panel">
        <ul class="nav-links nav-links--mobile">
          {links.map(l => (
            <li>
              <a href={l.href} class={`nav-link ${isActive(l.href) ? 'nav-link--active' : ''}`}>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="nav-mobile-actions">
          <a href={otherLangHref} class="lang-toggle" aria-label={`Switch language to ${otherLang.toUpperCase()}`}>
            <span class:list={['lang-chip', currentLang === 'ko' && 'lang-chip--active']}>KO</span>
            <span class:list={['lang-chip', currentLang === 'en' && 'lang-chip--active']}>EN</span>
          </a>
          <SocialLinks size="sm" />
        </div>
      </div>
    </details>
  </div>
  <script>
    document.addEventListener('click', (event) => {
      const mobileNav = document.querySelector('.nav-mobile');
      if (!(mobileNav instanceof HTMLDetailsElement)) return;
      if (mobileNav.contains(event.target)) return;
      mobileNav.open = false;
    });

    document.querySelectorAll('.nav-mobile-panel a').forEach((link) => {
      link.addEventListener('click', () => {
        const mobileNav = document.querySelector('.nav-mobile');
        if (mobileNav instanceof HTMLDetailsElement) mobileNav.open = false;
      });
    });
  </script>
</nav>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid #21262d;
  }

  .nav-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    transition: filter 0.2s;
  }
  .logo:hover { filter: drop-shadow(0 0 8px rgba(250, 204, 21, 0.6)); }
  .logo-name {
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #facc15;
  }
  .logo-sub {
    font-size: 0.72rem;
    font-family: "JetBrains Mono", monospace;
    color: #8b949e;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-mobile {
    display: none;
  }

  .nav-mobile-summary {
    list-style: none;
  }

  .nav-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .hamburger {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    border: 1px solid #30363d;
    background: rgba(250, 204, 21, 0.03);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.22rem;
  }

  .hamburger span {
    width: 0.95rem;
    height: 1.5px;
    background: #facc15;
    border-radius: 999px;
  }

  .nav-mobile-lang {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem;
    border: 1px solid #30363d;
    border-radius: 999px;
    background: rgba(250, 204, 21, 0.03);
    gap: 0.2rem;
  }

  .nav-mobile-panel {
    margin-top: 0.7rem;
    padding: 0.85rem;
    border: 1px solid #21262d;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.96);
  }

  .nav-links--mobile {
    flex-direction: column;
    gap: 0.2rem;
  }

  .nav-mobile-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.85rem;
  }

  .nav-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    font-size: 0.82rem;
    color: #8b949e;
    transition: color 0.2s, text-shadow 0.2s;
  }
  .nav-link:hover {
    color: #e6edf3;
    text-shadow: 0 0 10px rgba(250, 204, 21, 0.18);
  }
  .nav-link--active {
    color: #facc15;
    text-shadow: 0 0 10px rgba(250, 204, 21, 0.4);
  }

  .lang-toggle {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem;
    border: 1px solid #30363d;
    border-radius: 999px;
    background: rgba(250, 204, 21, 0.03);
    gap: 0.2rem;
  }

  .lang-chip {
    font-size: 0.68rem;
    font-family: "JetBrains Mono", monospace;
    padding: 0.22rem 0.5rem;
    border-radius: 999px;
    color: #8b949e;
    transition: color 0.2s, background 0.2s;
  }

  .lang-chip--active {
    background: rgba(250, 204, 21, 0.14);
    color: #facc15;
  }

  @media (max-width: 900px) {
    .nav-inner {
      padding: 0.8rem 1rem;
    }

    .nav-right {
      gap: 0.9rem;
    }

    .nav-links {
      gap: 0.75rem;
    }

    .nav-link {
      font-size: 0.78rem;
    }

    .logo-name {
      font-size: 0.88rem;
    }

    .logo-sub,
    .lang-chip {
      font-size: 0.64rem;
    }
  }

  @media (max-width: 720px) and (pointer: coarse) {
    .nav-inner {
      padding: 0.8rem 1rem 0.95rem;
    }

    .nav-right--desktop {
      display: none;
    }

    .nav-mobile {
      display: block;
    }

    .nav-mobile-summary {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      cursor: pointer;
    }

    .nav-mobile-panel .nav-link {
      display: inline-flex;
      align-items: center;
      min-height: 2.2rem;
      padding: 0.1rem 0;
    }
  }

  @media (max-width: 480px) and (pointer: coarse) {
    .nav-inner {
      gap: 0.75rem;
    }

    .logo-name {
      font-size: 0.88rem;
    }

    .nav-mobile-summary {
      justify-content: space-between;
      width: 100%;
    }

    .nav-mobile-panel {
      padding: 0.8rem;
    }

    .nav-mobile-actions {
      flex-wrap: wrap;
    }
  }
</style>
