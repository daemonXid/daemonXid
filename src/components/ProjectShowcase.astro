---
import type { PortfolioMediaItem } from '../lib/portfolioMedia'

interface TechSection {
  title: string
  body?: string
  bullets?: string[]
  code?: string
}

interface Props {
  media?: PortfolioMediaItem[]
  mediaLabel?: string
  techSections?: TechSection[]
  techLabel?: string
}

const {
  media = [],
  mediaLabel = 'Media',
  techSections = [],
  techLabel = 'Technical Notes',
} = Astro.props
---

{media.length > 0 && (
  <section class="showcase-block">
    <h2 class="showcase-label">{mediaLabel}</h2>
    <div class="media-grid">
      {media.map((item) => (
        <figure class="media-card">
          {item.type === 'image' ? (
            <img src={item.src} alt={item.title} loading="lazy" class="media-asset" />
          ) : (
            <video
              src={item.src}
              controls
              preload="metadata"
              playsinline
              class="media-asset"
              poster={item.poster}
            />
          )}
          <figcaption class="media-meta">
            <span class="media-title">{item.title}</span>
            {item.caption && <span class="media-caption">{item.caption}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
)}

{techSections.length > 0 && (
  <section class="showcase-block">
    <h2 class="showcase-label">{techLabel}</h2>
    <div class="notes-grid">
      {techSections.map((section) => (
        <article class="note-card">
          <h3 class="note-title">{section.title}</h3>
          {section.body && <p class="note-body">{section.body}</p>}
          {section.bullets && (
            <ul class="note-list">
              {section.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
          {section.code && <pre class="note-code"><code>{section.code}</code></pre>}
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .showcase-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .showcase-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 204, 21, 0.72);
  }

  .media-grid,
  .notes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .media-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .notes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .media-card,
  .note-card {
    border: 1px solid rgba(250, 204, 21, 0.12);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 12px;
    overflow: hidden;
  }

  .media-asset {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: linear-gradient(180deg, rgba(250, 204, 21, 0.03), rgba(255, 255, 255, 0.01));
  }

  .media-meta,
  .note-card {
    padding: 0.95rem 1rem;
  }

  .media-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .media-title,
  .note-title {
    color: #e6edf3;
    font-size: 0.86rem;
    font-weight: 600;
  }

  .media-caption,
  .note-body,
  .note-list {
    color: #8b949e;
    font-size: 0.8rem;
    line-height: 1.65;
  }

  .note-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .note-list {
    margin: 0;
    padding-left: 1rem;
  }

  .note-code {
    margin: 0;
    padding: 0.9rem;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(250, 204, 21, 0.08);
    color: #d0d7de;
    font-size: 0.72rem;
    line-height: 1.6;
    overflow-x: auto;
  }
</style>
