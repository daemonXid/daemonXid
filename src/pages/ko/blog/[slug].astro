---
import { getCollection, render } from 'astro:content'
import BlogPost from '../../../layouts/BlogPost.astro'
import { findTranslatedPost, getBlogPath } from '../../../lib/blogTranslations'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts
    .filter(post => post.data.lang === 'ko')
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }))
}

const { post } = Astro.props
const posts = await getCollection('blog')
const translated = findTranslatedPost(posts, post, 'en')
const langToggleHref = translated ? getBlogPath(translated) : '/blog'
const { Content } = await render(post)
---

<BlogPost frontmatter={post.data} lang="ko" langToggleHref={langToggleHref}>
  <Content />
</BlogPost>
