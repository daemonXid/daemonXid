---
import Base from '../../../layouts/Base.astro'
import ProjectMetaBar from '../../../components/ProjectMetaBar.astro'
import ProjectShowcase from '../../../components/ProjectShowcase.astro'
import SkillBadge from '../../../components/SkillBadge.astro'
import { getPortfolioMedia } from '../../../lib/portfolioMedia'

const stack = ['Django', 'Naver News API', 'BeautifulSoup4', 'Gemini API', 'PostgreSQL', 'Pydantic']
const media = getPortfolioMedia('lawngood', {
  dashboard: '수집 기사, 분류 결과, 사건 검토를 보는 화면.',
  pipeline: '수집, 파싱, 분류, 검토 흐름을 보여주는 그림.',
  demo: '기사 수집과 리뷰 흐름을 짧게 보여주는 영상.',
})
const techSections = [
  {
    title: '파이프라인 메모',
    bullets: [
      'Naver News API를 1차 기사 발굴 소스로 사용합니다.',
      'BeautifulSoup4가 본문을 정제하고 분석 가능한 텍스트로 만듭니다.',
      'Gemini 분류 결과는 Pydantic 검증 뒤 저장되어 리뷰 흐름으로 연결됩니다.',
    ],
  },
  {
    title: '데이터 모델 스냅샷',
    code: `articles
- id
- source_url
- title
- published_at

analyses
- article_id
- relevance_score
- risk_label
- summary

cases
- id
- case_name
- status

case_articles
- case_id
- article_id
- match_reason`,
  },
]
const metaItems = [
  { label: 'Role', value: '백엔드 및 AI 워크플로우 구현' },
  { label: 'Team', value: '2인 인턴십 팀' },
  { label: 'Period', value: '2026.02 - 2026.03' },
  { label: 'Links', value: 'GitHub 공개 · Live 없음' },
]
---

<Base title="LawNGood | Wonsub Song (Tony)" lang="ko" description="LawNGood 케이스 스터디: LawAndGood를 위해 만든 법률 뉴스 모니터링 POC입니다.">
  <a href="/ko/portfolio" class="back-link">← 포트폴리오</a>

  <header class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="text-3xl font-bold">LawNGood</h1>
      <span class="status-poc">POC</span>
    </div>
    <p class="lead">LawAndGood의 사건 발굴 및 검토 흐름을 지원하기 위해 만든 법률 뉴스 모니터링 proof of concept입니다.</p>
    <p class="meta">2인 인턴십 팀 · 2026.02 - 2026.03</p>
    <ProjectMetaBar items={metaItems} />
    <div class="flex flex-wrap gap-2 mb-6">
      {stack.map(s => <SkillBadge name={s} />)}
    </div>
    <a href="https://github.com/ken-do-it/law_news_c_v2" target="_blank" rel="noopener" class="cta-secondary">GitHub →</a>
  </header>

  <div class="content-wrap">
    <section>
      <h2 class="case-label">배경</h2>
      <p class="leading-relaxed">LawAndGood 인턴십에서 2인 팀으로 진행한 프로젝트입니다. 수동 키워드 검색에 의존하지 않고, 법률 분쟁 관련 뉴스 신호를 더 빠르고 일관되게 검토할 수 있는 흐름이 필요했습니다.</p>
    </section>

    <section>
      <h2 class="case-label">해결하려던 문제</h2>
      <ul class="space-y-2 text-sm">
        <li>→ 수동 검색 중심의 모니터링은 커버리지가 좁고 담당자별 편차가 컸습니다</li>
        <li>→ 기사 단위 검토를 사람이 직접 반복해야 해서 분류 속도가 느렸습니다</li>
        <li>→ 수집, 분류, 사건 검토를 하나의 흐름으로 연결할 내부 도구가 필요했습니다</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">구현 내용</h2>
      <ul class="space-y-2 text-sm">
        <li>→ Naver News API 기반 뉴스 수집 흐름</li>
        <li>→ BeautifulSoup4를 활용한 기사 본문 파싱 및 정제</li>
        <li>→ Gemini 기반 법률 분쟁 관련성 및 리스크 분류 흐름</li>
        <li>→ Pydantic 스키마를 통한 구조화된 LLM 출력 검증</li>
        <li>→ 사건과 기사 매칭 결과를 검토할 수 있는 Django 기반 리뷰 화면</li>
        <li>→ 기사 이력과 분류 결과를 저장하는 PostgreSQL 구조</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">내가 한 일</h2>
      <ul class="space-y-2 text-sm">
        <li>→ Naver News API와 BeautifulSoup4 기반 수집·파싱 흐름을 설계했습니다</li>
        <li>→ Gemini 기반 관련성 분류 파이프라인과 검증 구조를 구현했습니다</li>
        <li>→ 기사와 사건 검토를 연결하는 백엔드 리뷰 흐름을 만들었습니다</li>
        <li>→ 기사 이력, 분석 결과, 검토 상태를 PostgreSQL에 구조화했습니다</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">아키텍처</h2>
      <p class="leading-relaxed">수집 → 파싱 → 분류 → 검토, 단계별로 역할을 분리했습니다. Pydantic이 Gemini와 PostgreSQL 사이에서 스키마 검증을 담당해 구조화되지 않은 LLM 출력이 직접 DB에 저장되는 일이 없습니다.</p>

      <p class="diag-sub" style="margin-top:1.25rem;">파이프라인</p>
      <div class="flow-col">
        <div class="flow-row">
          <div class="flow-box fb-blue">Naver News API</div>
          <span class="flow-hint">1차 기사 발굴 소스</span>
        </div>
        <div class="flow-edge">↓ 수집</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">BeautifulSoup4</div>
          <span class="flow-hint">본문 파싱 · HTML 정제</span>
        </div>
        <div class="flow-edge">↓ 정제된 텍스트</div>
        <div class="flow-row">
          <div class="flow-box fb-yellow">Gemini API</div>
          <span class="flow-hint">relevance_score · risk_label · summary</span>
        </div>
        <div class="flow-edge">↓ 구조화 출력</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">Pydantic</div>
          <span class="flow-hint">스키마 검증 · 저장 안전 확인</span>
        </div>
        <div class="flow-edge">↓</div>
        <div class="flow-row">
          <div class="flow-box fb-green">PostgreSQL</div>
          <span class="flow-hint">articles · analyses · cases · case_articles</span>
        </div>
        <div class="flow-edge">↓</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">Django 리뷰 UI</div>
          <span class="flow-hint">모니터링 · 트리아지 · 사건-기사 매칭</span>
        </div>
      </div>
    </section>

    <section>
      <h2 class="case-label">결과</h2>
      <p class="leading-relaxed">작동하는 POC로 전달했습니다. 수동 뉴스 확인 중심의 작업을 더 구조화된 모니터링 흐름으로 바꾸고, 기사 수집부터 분류와 검토까지 한 시스템 안에서 다룰 수 있도록 만들었습니다.</p>
    </section>

    <ProjectShowcase media={media} techSections={techSections} mediaLabel="미디어" techLabel="기술 노트" />
  </div>
</Base>

<style>
  .back-link { display:inline-block; margin-bottom:2rem; color:#8b949e; font-size:0.8rem; }
  .back-link:hover { color:#facc15; }
  .status-poc { font-size:0.75rem; padding:0.2rem 0.5rem; border-radius:4px; background:#1a1a00; color:#facc15; border:1px solid #333300; }
  .lead { color:#a3adb8; font-size:1rem; margin-bottom:0.5rem; }
  .meta { color:#8b949e; font-size:0.82rem; margin-bottom:1.5rem; }
  .cta-secondary { padding:0.55rem 1rem; border-radius:6px; border:1px solid #333; color:#8b949e; display:inline-block; }
  .content-wrap { color:#a3adb8; display:flex; flex-direction:column; gap:3rem; }
  .case-label { font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:rgba(250, 204, 21, 0.72); margin-bottom:1rem; }
  .diag-sub { font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(250,204,21,0.4); margin-bottom: 0.65rem; font-family: "JetBrains Mono", monospace; }
  .flow-col { display: flex; flex-direction: column; align-items: flex-start; }
  .flow-row { display: flex; align-items: center; gap: 0.7rem; }
  .flow-box { font-family: "JetBrains Mono", monospace; font-size: 0.79rem; padding: 0.38rem 0.85rem; border-radius: 5px; border: 1px solid; white-space: nowrap; }
  .fb-blue  { color: #60a5fa; border-color: rgba(96,165,250,0.25);  background: rgba(96,165,250,0.05); }
  .fb-gray  { color: #e6edf3; border-color: rgba(255,255,255,0.1);  background: rgba(255,255,255,0.02); }
  .fb-yellow{ color: #facc15; border-color: rgba(250,204,21,0.25);  background: rgba(250,204,21,0.04); }
  .fb-green { color: #3fb950; border-color: rgba(63,185,80,0.25);   background: rgba(63,185,80,0.04); }
  .flow-edge { color: rgba(250,204,21,0.28); font-size: 0.72rem; font-family: "JetBrains Mono", monospace; margin: 0.18rem 0 0.18rem 1.1rem; }
  .flow-hint { font-size: 0.71rem; color: rgba(250,204,21,0.3); font-family: "JetBrains Mono", monospace; }
  @media (max-width: 640px) { .flow-hint { display: none; } }
</style>
