---
import Base from '../../../layouts/Base.astro'
import ProjectCard from '../../../components/ProjectCard.astro'

const b2b = [
  {
    name: 'LawNGood',
    desc: 'LawAndGood를 위해 만든 법률 뉴스 모니터링 POC로, Naver News API 수집과 기사 파싱, Gemini 분류를 결합했습니다.',
    stack: ['Django', 'Naver News API', 'BeautifulSoup4', 'Gemini API', 'PostgreSQL'],
    url: null,
    github: 'https://github.com/ken-do-it/law_news_c_v2',
    href: '/ko/portfolio/lawngood',
    status: 'live' as const,
  },
]

const architecture = [
  {
    name: 'DAEMON-KP',
    desc: '지식 플랫폼을 위한 Django 아키텍처 템플릿. 수집, Hybrid Search, 출처 기반 답변 흐름을 하나의 RAG 파이프라인으로 설계했습니다.',
    stack: ['Django', 'pgvector', 'pg_search', 'Gemini API', 'Pydantic AI'],
    url: null,
    github: null,
    href: '/ko/portfolio/daemon-kp',
    status: 'arch' as const,
  },
  {
    name: 'DAEMON-ONE',
    desc: 'AI 통합 모놀리스 제품을 위한 Django 아키텍처 템플릿. Modular Monolith, HTMX+SSR, Vertical Slicing, PostgreSQL-First를 핵심으로 합니다.',
    stack: ['Django', 'HTMX', 'pgvector', 'Pydantic'],
    url: null,
    github: null,
    href: '/ko/portfolio/daemon-one',
    status: 'arch' as const,
  },
]

const products = [
  {
    name: 'SportsIQ',
    desc: 'Multi-agent workflow, graphRAG, pgvector 기반으로 진행 중인 knowledge platform 프로젝트입니다.',
    stack: ['DAEMON-ONE', 'Multi-agent', 'graphRAG', 'pgvector'],
    url: null,
    github: null,
    href: '/ko/portfolio/kinetiq',
    status: 'offline' as const,
  },
  {
    name: 'Almaeng',
    desc: '성분 투명성과 가격 효율 비교를 다뤘던 AI 영양제 분석 및 가격 인텔리전스 프로젝트입니다.',
    stack: ['DAEMON-ONE', 'Django Ninja', 'HTMX', 'pgvector', 'Coolify'],
    url: null,
    github: null,
    href: '/ko/portfolio/almaeng',
    status: 'offline' as const,
  },
]
---

<Base title="Wonsub Song (Tony) | 포트폴리오" lang="ko" description="운영 중인 프로젝트, 케이스 스터디, 그리고 진행 중인 AI 제품 빌드를 정리했습니다.">
  <header class="mb-12">
    <h1 class="text-3xl font-bold mb-3">포트폴리오</h1>
    <p style="color:#8b949e;" class="text-sm">
      운영 중인 프로젝트와 진행 중인 빌드를 정리했습니다.
    </p>
  </header>

  <div class="portfolio-sections">
    <section class="portfolio-section">
      <h2 class="section-label">아키텍처</h2>
      <div class="cards-grid">
        {architecture.map(p => <ProjectCard {...p} />)}
      </div>
    </section>

    <section class="portfolio-section">
      <h2 class="section-label">B2B</h2>
      <div class="cards-grid">
        {b2b.map(p => <ProjectCard {...p} />)}
      </div>
    </section>

    <section class="portfolio-section">
      <h2 class="section-label">제품</h2>
      <div class="cards-grid">
        {products.map(p => <ProjectCard {...p} />)}
      </div>
    </section>
  </div>
</Base>

<style>
  .portfolio-sections { display: flex; flex-direction: column; gap: 3rem; }
  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 204, 21, 0.6);
    margin-bottom: 1rem;
  }
  .cards-grid { display: grid; grid-template-columns: 1fr; gap: 0.85rem; }
  @media (min-width: 640px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
