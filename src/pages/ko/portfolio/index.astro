---
import Base from '../../../layouts/Base.astro'
import ProjectCard from '../../../components/ProjectCard.astro'

const projects = [
  {
    name: 'Almaeng',
    desc: '성분 투명성과 가격 효율 비교에 초점을 맞춘 AI 영양제 분석 및 가격 인텔리전스 제품입니다. 2025.12에 출시했습니다.',
    stack: ['Django Ninja', 'HTMX', 'pgvector', 'Gemini Flash', 'Coolify'],
    url: null,
    github: null,
    href: '/ko/portfolio/almaeng',
    status: 'offline' as const,
  },
  {
    name: 'LawNGood',
    desc: 'LawAndGood를 위해 만든 법률 뉴스 모니터링 POC로, Naver News API 수집과 기사 파싱, Gemini 분류를 결합했습니다.',
    stack: ['Django', 'Naver News API', 'BeautifulSoup4', 'Gemini API', 'PostgreSQL'],
    url: null,
    github: 'https://github.com/ken-do-it/law_news_c_v2',
    href: '/ko/portfolio/LegalRadar',
    status: 'live' as const,
  },
  {
    name: 'SportsIQ',
    desc: 'Multi-agent workflow, graphRAG, Mirofish, pgvector 기반으로 진행 중인 knowledge platform 프로젝트입니다.',
    stack: ['Multi-agent', 'graphRAG', 'Mirofish', 'pgvector'],
    url: null,
    github: null,
    href: '/ko/portfolio/kinetiq',
    status: 'offline' as const,
  },
]
---

<Base title="Wonsub Song (Tony) | 포트폴리오" lang="ko" description="운영 중인 프로젝트, 케이스 스터디, 그리고 진행 중인 AI 제품 빌드를 정리했습니다.">
  <header class="mb-12">
    <h1 class="text-3xl font-bold mb-3">포트폴리오</h1>
    <p style="color:#8b949e;" class="text-sm">
      운영 중인 프로젝트와 진행 중인 빌드를 정리했습니다.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {projects.map(p => (
      <ProjectCard
        name={p.name}
        desc={p.desc}
        stack={p.stack}
        url={p.url}
        github={p.github}
        href={p.href}
        status={p.status}
      />
    ))}
  </div>
</Base>
