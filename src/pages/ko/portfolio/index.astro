---
import Base from '../../../layouts/Base.astro'
import ProjectCard from '../../../components/ProjectCard.astro'

const projects = [
  {
    name: 'Almaeng',
    desc: 'Naver Shopping 검색 데이터와 MFDS 공공 정보를 결합한 영양제 가격 인텔리전스 플랫폼입니다. 2025.12에 출시했습니다.',
    stack: ['Django', 'HTMX', 'PostgreSQL', 'Docker', 'Coolify'],
    url: 'https://almaeng.daemonx.cc',
    github: 'https://github.com/daemonxid/almaeng',
    href: '/ko/portfolio/almaeng',
    status: 'live' as const,
  },
  {
    name: 'LawNGood',
    desc: 'Naver News API 수집, BeautifulSoup4 파싱, Gemini 분류를 결합한 법률 뉴스 모니터링 POC입니다.',
    stack: ['Django', 'Naver News API', 'BeautifulSoup4', 'Gemini API', 'PostgreSQL'],
    url: null,
    github: 'https://github.com/ken-do-it/law_news_c_v2',
    href: '/ko/portfolio/LegalRadar',
    status: 'live' as const,
  },
  {
    name: 'SportsIQ',
    desc: 'Multi-agent workflow, graphRAG, Mirofish, pgvector 기반으로 진행 중인 knowledge platform 프로젝트입니다.',
    stack: ['Multi-agent', 'graphRAG', 'Mirofish', 'pgvector'],
    url: null,
    github: null,
    href: '/ko/portfolio/kinetiq',
    status: 'wip' as const,
  },
]
---

<Base title="Wonsub Song (Tony) | 포트폴리오" lang="ko">
  <header class="mb-12">
    <h1 class="text-3xl font-bold mb-3">포트폴리오</h1>
    <p style="color:#8b949e;" class="text-sm">
      운영 중인 프로젝트와 진행 중인 빌드를 정리했습니다.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {projects.map(p => (
      <ProjectCard
        name={p.name}
        desc={p.desc}
        stack={p.stack}
        url={p.url}
        github={p.github}
        href={p.href}
        status={p.status}
      />
    ))}
  </div>
</Base>
