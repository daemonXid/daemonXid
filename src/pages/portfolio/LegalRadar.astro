---
import Base from '../../layouts/Base.astro'
import ProjectMetaBar from '../../components/ProjectMetaBar.astro'
import ProjectShowcase from '../../components/ProjectShowcase.astro'
import SkillBadge from '../../components/SkillBadge.astro'
import { getPortfolioMedia } from '../../lib/portfolioMedia'

const stack = ['Django', 'Naver News API', 'BeautifulSoup4', 'Gemini API', 'PostgreSQL', 'Pydantic']
const media = getPortfolioMedia('lawngood', {
  dashboard: 'Review surface for collected articles, classifications, and case monitoring.',
  pipeline: 'Collection, parsing, classification, and review flow.',
  demo: 'Short walkthrough of article collection and review flow.',
})
const techSections = [
  {
    title: 'Pipeline Notes',
    bullets: [
      'Naver News API is used as the primary discovery source for legal-news collection.',
      'BeautifulSoup4 cleans and extracts article bodies before AI analysis.',
      'Gemini classification output is validated through Pydantic before being saved for review.',
    ],
  },
  {
    title: 'Data Model Snapshot',
    code: `articles
- id
- source_url
- title
- published_at

analyses
- article_id
- relevance_score
- risk_label
- summary

cases
- id
- case_name
- status

case_articles
- case_id
- article_id
- match_reason`,
  },
]
const metaItems = [
  { label: 'Role', value: 'Backend and AI workflow implementation' },
  { label: 'Team', value: '2-person internship team' },
  { label: 'Period', value: '2026.02.09 - 2026.03.06' },
  { label: 'Links', value: 'GitHub public · No live service' },
]
---

<Base title="LawNGood | Wonsub Song (Tony)" lang="en" description="LawNGood case study: a legal-news monitoring POC for LawAndGood with AI-based classification and review flow.">
  <a href="/portfolio" class="text-sm hover:text-white transition-colors mb-8 inline-block" style="color:#8b949e;">
    ← Portfolio
  </a>

  <header class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="text-3xl font-bold">LawNGood</h1>
      <span class="text-xs px-2 py-0.5 rounded" style="background:#1a1a00;color:#facc15;border:1px solid #333300;">
        POC
      </span>
    </div>
    <p class="text-lg mb-2" style="color:#a1a1aa;">
      Legal news monitoring proof of concept built for LawAndGood to support case discovery and litigation-finance review.
    </p>
    <p class="text-sm mb-6" style="color:#8b949e;">
      2-person internship team · 2026.02.09 - 2026.03.06
    </p>
    <ProjectMetaBar items={metaItems} />
    <div class="flex flex-wrap gap-2 mb-6">
      {stack.map(s => <SkillBadge name={s} />)}
    </div>
    <a href="https://github.com/ken-do-it/law_news_c_v2" target="_blank" rel="noopener"
       class="px-4 py-2 rounded text-sm hover:border-zinc-600 transition-colors inline-block"
       style="border:1px solid #333;color:#a1a1aa;">
      GitHub →
    </a>
  </header>

  <div class="space-y-12" style="color:#a1a1aa;">
    <section>
      <h2 class="case-label">Context</h2>
      <p class="leading-relaxed">
        Built in a 2-person internship team for LawAndGood via the Likelion Rocket program.
        The company needed a way to discover legal-dispute signals faster and review candidate cases with more consistency than a manual news search workflow.
      </p>
    </section>

    <section>
      <h2 class="case-label">Problem To Solve</h2>
      <ul class="space-y-2 text-sm">
        <li>→ Manual keyword search limited coverage and made monitoring dependent on individual effort</li>
        <li>→ Relevance review was slow because analysts had to read, compare, and triage articles one by one</li>
        <li>→ The team needed a structured way to connect article collection, AI judgment, and case review</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">What I Built</h2>
      <ul class="space-y-2 text-sm">
        <li>→ News collection flow using Naver News API as the primary source</li>
        <li>→ Article parsing and cleanup with BeautifulSoup4</li>
        <li>→ Gemini-based classification flow for dispute relevance and risk labeling</li>
        <li>→ Pydantic schemas to validate structured LLM output</li>
        <li>→ Django-based review interface for monitoring cases and article matches</li>
        <li>→ PostgreSQL storage for article history, classifications, and monitoring results</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">What I Did</h2>
      <ul class="space-y-2 text-sm">
        <li>→ Designed the article collection and parsing flow around Naver News API and BeautifulSoup4</li>
        <li>→ Implemented the Gemini-based relevance classification pipeline with validated outputs</li>
        <li>→ Built the backend review workflow for article-to-case monitoring</li>
        <li>→ Structured storage for article history, analysis results, and review state in PostgreSQL</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Architecture</h2>
      <p class="leading-relaxed">
        The pipeline separates collection, parsing, classification, and review. Naver News API provides the initial article set,
        BeautifulSoup4 extracts and cleans article content, Gemini evaluates legal relevance and monitoring value, and validated outputs
        move into Django and PostgreSQL for review. That structure kept the POC shippable within a short internship window while still
        making the AI output operationally usable.
      </p>
    </section>

    <section>
      <h2 class="case-label">Outcome</h2>
      <p class="leading-relaxed">
        Delivered as a working proof of concept. The result turned manual legal-news scanning into a more structured monitoring workflow,
        making it easier to collect signals, classify relevance, and review candidate cases inside one system.
      </p>
    </section>

    <ProjectShowcase media={media} techSections={techSections} />
  </div>
</Base>

<style>
  .case-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #52525b;
    margin-bottom: 1rem;
  }
</style>
