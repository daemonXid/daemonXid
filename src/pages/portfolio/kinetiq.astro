---
import Base from '../../layouts/Base.astro'
import SkillBadge from '../../components/SkillBadge.astro'

const stack = ['Python', 'MediaPipe', 'YOLO', 'Django', 'PostgreSQL', 'pgvector']
---

<Base title="SportsIQ | Wonsub Song (Tony)" lang="en">
  <a href="/portfolio" class="text-sm hover:text-white transition-colors mb-8 inline-block" style="color:#8b949e;">
    ← Portfolio
  </a>

  <header class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="text-3xl font-bold">SportsIQ</h1>
      <span class="text-xs px-2 py-0.5 rounded" style="background:#1a1a00;color:#facc15;border:1px solid #333300;">
        WIP
      </span>
    </div>
    <p class="text-lg mb-2" style="color:#a1a1aa;">
      Vision AI product for athlete movement analysis. Sports Science meets pose estimation.
    </p>
    <p class="text-sm mb-6" style="color:#52525b;">
      Ongoing · 2026
    </p>
    <div class="flex flex-wrap gap-2">
      {stack.map(s => <SkillBadge name={s} />)}
    </div>
  </header>

  <div class="space-y-12" style="color:#a1a1aa;">
    <section>
      <h2 class="case-label">Why This Exists</h2>
      <p class="leading-relaxed">
        Sports Science graduates spend years learning biomechanics, including joint angles, force vectors,
        and movement efficiency. In practice, applying that knowledge often depends on expensive motion-capture systems.
        SportsIQ is an attempt to bring that analysis into a more practical product using standard video and pose estimation.
      </p>
      <p class="leading-relaxed mt-3">
        The domain expertise is what turns raw pose keypoints into useful athletic feedback, rather than generic tracking output.
      </p>
    </section>

    <section>
      <h2 class="case-label">Planned Architecture</h2>
      <ul class="space-y-2 text-sm">
        <li>→ Video upload, frame extraction, and MediaPipe pose keypoints</li>
        <li>→ Biomechanical analysis for joint angles, symmetry, and range of motion</li>
        <li>→ pgvector storage for movement embeddings and cross-session comparison</li>
        <li>→ Django backend + HTMX interface for frame-by-frame review</li>
        <li>→ YOLO for multi-person tracking in team-sport scenarios</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Status</h2>
      <p class="leading-relaxed">
        Ongoing in 2026. Architecture is defined and implementation is in progress.
        Updates will be posted in <a href="/blog" class="hover:text-white transition-colors" style="color:#facc15;">the blog</a>.
      </p>
    </section>
  </div>
</Base>

<style>
  .case-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #52525b;
    margin-bottom: 1rem;
  }
</style>
