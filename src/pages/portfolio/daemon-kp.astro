---
import Base from '../../layouts/Base.astro'
import ProjectMetaBar from '../../components/ProjectMetaBar.astro'
import SkillBadge from '../../components/SkillBadge.astro'

const stack = ['Django', 'HTMX', 'pgvector', 'pg_search', 'Gemini API', 'Pydantic AI', 'Taskiq', 'Docker', 'Coolify']
const metaItems = [
  { label: 'Type', value: 'Architecture template' },
  { label: 'Role', value: 'Designer & sole author' },
  { label: 'Repository', value: 'Private · available on request' },
  { label: 'Built on it', value: 'SportsIQ' },
]
---

<Base title="DAEMON-KP | Wonsub Song (Tony)" lang="en" description="DAEMON-KP: Django architecture template for knowledge platforms. End-to-end RAG pipeline — Source → Document → Chunk → Hybrid Search → Grounded Answer → Citation.">
  <a href="/portfolio" class="text-sm hover:text-white transition-colors mb-8 inline-block" style="color:#8b949e;">
    ← Portfolio
  </a>

  <header class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="text-3xl font-bold">DAEMON-KP</h1>
      <span style="font-size:0.75rem;padding:0.2rem 0.5rem;border-radius:4px;background:#0a1628;color:#60a5fa;border:1px solid #1e3a5f;font-family:'JetBrains Mono',monospace;font-weight:700;letter-spacing:0.04em;">
        ARCH
      </span>
    </div>
    <p class="text-lg mb-2" style="color:#a1a1aa;">
      A Django architecture template for knowledge platforms — an end-to-end RAG pipeline from source ingestion to citation-grounded answers.
    </p>
    <p class="text-sm mb-6" style="color:#52525b;">
      Private repository · Available on request
    </p>
    <ProjectMetaBar items={metaItems} />
    <div class="flex flex-wrap gap-2">
      {stack.map(s => <SkillBadge name={s} />)}
    </div>
  </header>

  <div class="space-y-12" style="color:#a1a1aa;">
    <section>
      <h2 class="case-label">Why It Exists</h2>
      <p class="leading-relaxed">
        Every knowledge product faces the same structural problem: getting from raw sources to answers
        a user can actually trust. The pipeline sounds simple — ingest, chunk, search, answer — but the
        failure modes compound: hallucinated citations, keyword-only search missing semantic intent, semantic
        search missing exact terms. DAEMON-KP is the architecture I designed to solve that, purpose-built for
        knowledge-heavy products where answer quality is the product.
      </p>
    </section>

    <section>
      <h2 class="case-label">Pipeline</h2>
      <div class="pipeline-row">
        <span class="pipe-step">Source</span>
        <span class="pipe-arrow">→</span>
        <span class="pipe-step">Document</span>
        <span class="pipe-arrow">→</span>
        <span class="pipe-step">Chunk</span>
        <span class="pipe-arrow">→</span>
        <span class="pipe-step">Search</span>
        <span class="pipe-arrow">→</span>
        <span class="pipe-step">Answer</span>
        <span class="pipe-arrow">→</span>
        <span class="pipe-step">Citation</span>
      </div>
      <p class="leading-relaxed text-sm mt-4">
        Each stage is a typed Pydantic boundary — a chunk that doesn't meet quality criteria never reaches the search index.
        An answer that can't be grounded in retrieved context is flagged, not surfaced.
      </p>
      <div class="completeness-table">
        <div class="ct-row ct-header">
          <span>Stage</span><span>Status</span>
        </div>
        <div class="ct-row">
          <span>Chunking (heading-aware, 1200 chars / 150 overlap)</span>
          <span class="ct-done">Complete</span>
        </div>
        <div class="ct-row">
          <span>Lexical Search (Django FTS)</span>
          <span class="ct-done">Complete</span>
        </div>
        <div class="ct-row">
          <span>Hybrid Search (45% lexical + 55% semantic)</span>
          <span class="ct-done">Complete</span>
        </div>
        <div class="ct-row">
          <span>AI Answer + Citation (Gemini 2.5-flash)</span>
          <span class="ct-done">Complete</span>
        </div>
        <div class="ct-row">
          <span>Semantic Search (pgvector HNSW)</span>
          <span class="ct-partial">60% — embedding task stub</span>
        </div>
        <div class="ct-row">
          <span>Source Ingestion (URL/File parser)</span>
          <span class="ct-partial">30% — parsers.py stub</span>
        </div>
      </div>
      <p class="text-sm" style="color:#52525b;margin-top:0.75rem;">Core RAG flow (chunking → lexical search → AI answer) works out of the box.</p>

      <p class="diag-sub" style="margin-top:1.5rem;">Detailed Flow</p>
      <div class="flow-col">
        <div class="flow-row">
          <div class="flow-box fb-blue">Source</div>
          <span class="flow-hint">URL · File · API</span>
        </div>
        <div class="flow-edge">↓ parse (parsers.py)</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">Document</div>
          <span class="flow-hint">title · body · slug · summary</span>
        </div>
        <div class="flow-edge">↓ auto-chunk on save (1200 chars, 150 overlap)</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">Chunks</div>
          <span class="flow-hint">heading-aware · content_hash dedup</span>
        </div>
        <div class="flow-edge">↓ embed → pgvector HNSW · index → pg_search BM25</div>
        <div class="flow-row">
          <div class="flow-box fb-gray">Search Index</div>
          <span class="flow-hint">BM25 (45%) + cosine similarity (55%) → fused score</span>
        </div>
        <div class="flow-edge">↓ top-K chunks passed to LLM</div>
        <div class="flow-row">
          <div class="flow-box fb-yellow">Answer</div>
          <span class="flow-hint">Gemini 2.5-flash · grounded generation · structured output</span>
        </div>
        <div class="flow-edge">↓ source_ids in response</div>
        <div class="flow-row">
          <div class="flow-box fb-green">Citation</div>
          <span class="flow-hint">Chunk → Document · always traceable</span>
        </div>
      </div>
    </section>

    <section>
      <h2 class="case-label">Domain Map</h2>
      <div class="domain-map">
        <div class="domain-group">
          <p class="dg-label">Knowledge Core</p>
          <div class="dg-tags">
            <span class="dg-tag">sources</span>
            <span class="dg-tag">documents</span>
            <span class="dg-tag">chunks</span>
            <span class="dg-tag">topics</span>
          </div>
        </div>
        <div class="domain-group">
          <p class="dg-label">Intelligence</p>
          <div class="dg-tags">
            <span class="dg-tag">search</span>
            <span class="dg-tag">answers</span>
            <span class="dg-tag">entities</span>
          </div>
        </div>
        <div class="domain-group">
          <p class="dg-label">Interaction</p>
          <div class="dg-tags">
            <span class="dg-tag">discussions</span>
            <span class="dg-tag">workspace</span>
          </div>
        </div>
        <div class="domain-group">
          <p class="dg-label">Pipeline</p>
          <div class="dg-tags">
            <span class="dg-tag">ingestion</span>
          </div>
        </div>
        <div class="domain-group dg-span2">
          <p class="dg-label">Foundation</p>
          <div class="dg-tags">
            <span class="dg-tag">core</span>
            <span class="dg-tag">accounts</span>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="case-label">Key Decisions</h2>
      <ul class="space-y-5 text-sm">
        <li>
          <p style="color:#e6edf3;font-weight:600;margin-bottom:0.3rem;">Hybrid Search (BM25 + vector similarity)</p>
          <p class="leading-relaxed">
            <code>pg_search</code> (BM25 ranking) + <code>pgvector</code> (semantic similarity), scores fused at query time
            with a 45/55 split. Handles both "what is X" and "find the document that mentions Y" — neither alone is sufficient.
          </p>
        </li>
        <li>
          <p style="color:#e6edf3;font-weight:600;margin-bottom:0.3rem;">Citation-First Answers</p>
          <p class="leading-relaxed">
            Answers are generated only from retrieved chunks. Gemini receives chunk IDs directly and returns structured output
            with <code>source_ids</code> alongside the answer text — no post-hoc attribution. If context doesn't support an
            answer, the system says so.
          </p>
        </li>
        <li>
          <p style="color:#e6edf3;font-weight:600;margin-bottom:0.3rem;">PostgreSQL-Only (no separate vector DB)</p>
          <p class="leading-relaxed">
            <code>pgvector</code> + <code>pg_search</code> inside the same PostgreSQL instance. No Pinecone, no Elasticsearch,
            no sync overhead. The search index is always consistent with the document store by construction.
          </p>
        </li>
        <li>
          <p style="color:#e6edf3;font-weight:600;margin-bottom:0.3rem;">Built on DAEMON-ONE</p>
          <p class="leading-relaxed">
            DAEMON-KP is a domain-layer extension of DAEMON-ONE. 12 domains — <code>documents</code>, <code>chunks</code>,
            <code>search</code>, <code>answers</code>, <code>sources</code>, <code>topics</code>, <code>discussions</code>,
            <code>entities</code>, <code>ingestion</code>, <code>workspace</code>, <code>accounts</code>, <code>core</code> —
            each following the same Vertical Slicing and <code>interface.py</code> boundary rules.
            Drop the <code>knowledge/</code> domain folder and the RAG system is gone cleanly.
          </p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Target Products</h2>
      <ul class="space-y-1 text-sm">
        <li style="color:#e6edf3;">Sports Science Platform &nbsp;· University Wiki &nbsp;· Research Explorer &nbsp;· Recipe Archive</li>
        <li class="leading-relaxed" style="margin-top:0.5rem;">Any product where documents are the data model and answers need to cite their sources.</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Related Writing</h2>
      <ul class="space-y-2 text-sm">
        <li>→ <a href="/blog/postgres-first-architecture-en" style="color:#facc15;" class="hover:text-white transition-colors">PostgreSQL-First Architecture: You Can Go Far Without Redis</a></li>
        <li>→ <a href="/blog/django-interface-py-domain-boundary-en" style="color:#facc15;" class="hover:text-white transition-colors">Django Domain Boundaries: Why I Force an interface.py</a></li>
        <li>→ <a href="/blog/vertical-slice-en" style="color:#facc15;" class="hover:text-white transition-colors">Why I Prefer Vertical Slice Architecture</a></li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Built On DAEMON-KP</h2>
      <ul class="space-y-2 text-sm">
        <li>→ <a href="/portfolio/kinetiq" style="color:#facc15;" class="hover:text-white transition-colors">SportsIQ</a> — Sports knowledge platform, in development</li>
      </ul>
    </section>

    <section>
      <h2 class="case-label">Status</h2>
      <p class="leading-relaxed">
        Private repository. The pipeline evolves with SportsIQ as the proving ground.
        Available on request.
      </p>
    </section>
  </div>
</Base>

<style>
  .case-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #52525b;
    margin-bottom: 1rem;
  }
  code {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82em;
    color: #facc15;
    background: rgba(250,204,21,0.06);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .pipeline-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
  }
  .pipe-step {
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(96, 165, 250, 0.06);
    border: 1px solid rgba(96, 165, 250, 0.18);
    color: #60a5fa;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .pipe-arrow { color: #52525b; font-size: 0.9rem; }
  .completeness-table {
    margin-top: 1rem;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    overflow: hidden;
    font-size: 0.8rem;
    font-family: "JetBrains Mono", monospace;
  }
  .ct-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: center;
  }
  .ct-row:last-child { border-bottom: none; }
  .ct-header { color: #52525b; font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; background: rgba(255,255,255,0.02); }
  .ct-done { color: #3fb950; white-space: nowrap; }
  .ct-partial { color: rgba(250, 204, 21, 0.7); white-space: nowrap; }

  /* diagram */
  .diag-sub { font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: #52525b; margin-bottom: 0.65rem; font-family: "JetBrains Mono", monospace; }
  .flow-col { display: flex; flex-direction: column; align-items: flex-start; }
  .flow-row { display: flex; align-items: center; gap: 0.7rem; }
  .flow-box { font-family: "JetBrains Mono", monospace; font-size: 0.79rem; padding: 0.38rem 0.85rem; border-radius: 5px; border: 1px solid; white-space: nowrap; }
  .fb-blue  { color: #60a5fa; border-color: rgba(96,165,250,0.25);  background: rgba(96,165,250,0.05); }
  .fb-gray  { color: #e6edf3; border-color: rgba(255,255,255,0.1);  background: rgba(255,255,255,0.02); }
  .fb-yellow{ color: #facc15; border-color: rgba(250,204,21,0.25);  background: rgba(250,204,21,0.04); }
  .fb-green { color: #3fb950; border-color: rgba(63,185,80,0.25);   background: rgba(63,185,80,0.04); }
  .flow-edge { color: rgba(250,204,21,0.28); font-size: 0.72rem; font-family: "JetBrains Mono", monospace; margin: 0.18rem 0 0.18rem 1.1rem; }
  .flow-hint { font-size: 0.71rem; color: #52525b; font-family: "JetBrains Mono", monospace; }
  .domain-map { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
  .domain-group { padding: 0.7rem 0.85rem; border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; background: rgba(255,255,255,0.01); }
  .dg-span2 { grid-column: span 2; }
  .dg-label { font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(250,204,21,0.5); margin-bottom: 0.5rem; font-family: "JetBrains Mono", monospace; }
  .dg-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .dg-tag { font-size: 0.72rem; font-family: "JetBrains Mono", monospace; padding: 0.15rem 0.45rem; border-radius: 3px; background: rgba(96,165,250,0.06); border: 1px solid rgba(96,165,250,0.15); color: #60a5fa; }

  @media (max-width: 640px) {
    .mb-12 { margin-bottom: 2.25rem; }
    .text-3xl { font-size: 1.75rem; line-height: 1.2; }
    .text-lg { font-size: 1rem; line-height: 1.65; }
    .space-y-12 > :not([hidden]) ~ :not([hidden]) { margin-top: 2.2rem; }
    .leading-relaxed { line-height: 1.75; }
    .pipeline-row { gap: 0.3rem; }
    .pipe-step { font-size: 0.72rem; padding: 0.2rem 0.45rem; }
    .ct-row { grid-template-columns: 1fr; gap: 0.2rem; }
    .ct-done, .ct-partial { font-size: 0.72rem; }
    .flow-hint { display: none; }
    .domain-map { grid-template-columns: 1fr; }
    .dg-span2 { grid-column: span 1; }
  }
</style>
