---
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE, SITE_NAME, SITE_URL } from '../lib/siteMeta'
import '../styles/global.css'

interface Props {
  title: string
  lang?: 'en' | 'ko'
  description?: string
  ogImage?: string
  noindex?: boolean
  langToggleHref?: string
}

const {
  title,
  lang = 'en',
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  noindex = false,
  langToggleHref,
} = Astro.props
const canonical = new URL(Astro.url.pathname, SITE_URL).toString()
const ogUrl = new URL(ogImage, SITE_URL).toString()
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="generator" content={SITE_NAME} />
  <meta name="theme-color" content="#0d1117" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <Nav lang={lang} langToggleHref={langToggleHref} />
  <main class="max-w-3xl mx-auto px-6 py-16">
    <slot />
  </main>
  <Footer />

  <!-- 3D card tilt effect -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll<HTMLElement>('[data-card-3d]')

      cards.forEach(card => {
        card.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = card.getBoundingClientRect()
          const x = e.clientX - rect.left
          const y = e.clientY - rect.top
          const cx = rect.width / 2
          const cy = rect.height / 2
          const rotX = ((cy - y) / cy) * 8
          const rotY = ((x - cx) / cx) * 8
          card.style.transform =
            `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateZ(10px)`
        })

        card.addEventListener('mouseleave', () => {
          card.style.transform =
            'perspective(1000px) rotateX(0deg) rotateY(0deg) translateZ(0px)'
        })
      })
    })
  </script>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {
          // Keep PWA registration failure silent for a personal site.
        })
      })
    }
  </script>
</body>
</html>
