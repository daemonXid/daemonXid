---
import Base from './Base.astro'

interface Props {
  frontmatter: {
    title: string
    excerpt?: string
    date: Date
    category: string
    translationKey: string
    tags?: string[]
    lang?: string
  }
  lang?: 'en' | 'ko'
  langToggleHref?: string
}

const { frontmatter, lang = 'en', langToggleHref } = Astro.props
const { title, excerpt, date, category, tags = [], lang: postLang = 'ko' } = frontmatter
const backHref = lang === 'ko' ? '/ko/blog' : '/blog'
const backLabel = lang === 'ko' ? '← 블로그' : '← Blog'
---

<Base title={`${title} | Wonsub Song (Tony)`} lang={lang} description={excerpt ?? title} langToggleHref={langToggleHref}>
  <a href={backHref} class="back-link">{backLabel}</a>

  <article>
    <header class="post-header">
      <div class="post-meta">
        <span class="meta-cat">{category}</span>
        <span class="meta-sep">·</span>
        <time class="meta-date">{date.toISOString().slice(0, 10)}</time>
        {postLang === 'ko' && <><span class="meta-sep">·</span><span class="meta-lang">KO</span></>}
      </div>
      <h1 class="post-title">{title}</h1>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2.5rem;
    font-size: 0.78rem;
    font-family: "JetBrains Mono", monospace;
    color: #8b949e;
    transition: color 0.2s;
  }
  .back-link:hover { color: #facc15; }

  .post-header { margin-bottom: 3rem; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.7rem;
    font-family: "JetBrains Mono", monospace;
  }
  .meta-cat  { color: rgba(250, 204, 21, 0.5); text-transform: uppercase; letter-spacing: 0.1em; }
  .meta-sep  { color: #30363d; }
  .meta-date { color: #8b949e; }
  .meta-lang { color: #8b949e; }

  .post-title {
    font-size: clamp(1.6rem, 5vw, 2.1rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    background: linear-gradient(135deg, #e6edf3 30%, #facc15 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    font-size: 0.66rem;
    font-family: "JetBrains Mono", monospace;
    padding: 0.2em 0.5em;
    border-radius: 4px;
    background: rgba(250, 204, 21, 0.06);
    border: 1px solid rgba(250, 204, 21, 0.15);
    color: rgba(250, 204, 21, 0.78);
  }

  /* Prose — :global() required for <Content /> rendered HTML */
  .prose {
    color: #8b949e;
    line-height: 1.85;
    font-size: 0.92rem;
  }

  .prose :global(h2) {
    color: #facc15;
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
    opacity: 0.85;
  }
  .prose :global(h3) {
    color: #e6edf3;
    font-size: 0.98rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
  }
  .prose :global(p)  { margin-bottom: 1.2rem; }
  .prose :global(ul),
  .prose :global(ol) { margin-bottom: 1.2rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.35rem; }

  .prose :global(code) {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82em;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background: rgba(250, 204, 21, 0.07);
    border: 1px solid rgba(250, 204, 21, 0.15);
    color: #facc15;
  }
  .prose :global(pre) {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 8px;
    padding: 1.2rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #e6edf3;
    font-size: 0.85rem;
  }
  .prose :global(strong) { color: #e6edf3; font-weight: 600; }
  .prose :global(a) {
    color: #facc15;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(250, 204, 21, 0.3);
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) { text-decoration-color: #facc15; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid #21262d;
    margin: 2.5rem 0;
  }
  .prose :global(blockquote) {
    border-left: 2px solid rgba(250, 204, 21, 0.3);
    padding-left: 1.2rem;
    color: #a3adb8;
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>
